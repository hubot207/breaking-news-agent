# Copy this file to `.env` and fill in your credentials.
# Never commit `.env` to git.

# ===== Core =====
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/agent.db
POLL_INTERVAL_SECONDS=60

# ===== AI provider =====
# Pick one. Cheap-to-expensive: Gemini Flash (free tier) -> GPT-4o-mini -> Claude Haiku.
#
# To use Google Gemini (cheapest, has free tier):
#   AI_PROVIDER=openai
#   AI_MODEL=gemini-2.0-flash
#   OPENAI_API_KEY=<your gemini api key from ai.google.dev>
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#
# To use OpenAI directly:
#   AI_PROVIDER=openai
#   AI_MODEL=gpt-4o-mini
#   OPENAI_API_KEY=sk-...
#   (leave OPENAI_BASE_URL empty)
#
# To use Anthropic:
#   AI_PROVIDER=anthropic
#   AI_MODEL=claude-haiku-4-5-20251001
#   ANTHROPIC_API_KEY=sk-ant-...
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_MODEL=claude-haiku-4-5-20251001

# Cap LLM calls per minute (sliding window). Prevents 429s and runaway cost.
# 0 = disabled. Suggested: 12 (Gemini free), 60 (paid tiers), 200 (high volume).
AI_RATE_LIMIT_RPM=60

# Per-platform daily post caps. 0 = unlimited.
# X: aggressive cap - high posting frequency hurts X's algorithm and
# bills add up at $0.01/post. 15-30/day is the sweet spot for engagement.
# Threads: similar dynamics; cap below Telegram.
# Telegram: unlimited - direct subscribers, no algorithm penalty.
# YouTube: low cap - video assembly is expensive.
X_DAILY_POST_LIMIT=15
THREADS_DAILY_POST_LIMIT=25
TELEGRAM_DAILY_POST_LIMIT=0
YOUTUBE_DAILY_POST_LIMIT=5

# ===== News sources =====
# Comma-separated RSS URLs to poll
# AI/tech-focused feeds for the Synapse niche.
# Verify each is reachable from your laptop with `curl -sIL <url>` before deploying.
RSS_FEEDS=https://news.ycombinator.com/rss,https://techcrunch.com/category/artificial-intelligence/feed/,https://venturebeat.com/category/ai/feed/,https://www.theverge.com/ai-artificial-intelligence/rss/index.xml,https://feeds.arstechnica.com/arstechnica/technology-lab,https://the-decoder.com/feed/
NEWSAPI_KEY=

# ===== X (Twitter) =====
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ===== Threads =====
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel

# ===== YouTube =====
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=

# ===== Feature flags =====
ENABLE_X=true
ENABLE_THREADS=false
ENABLE_TELEGRAM=true
ENABLE_YOUTUBE=false
DRY_RUN=true

# ===== Observability =====
# Source token from Better Stack (telemetry.betterstack.com).
# Leave empty to skip log shipping; the vector container exits cleanly.
BETTERSTACK_SOURCE_TOKEN=
