# Copy this file to `.env` and fill in your credentials.
# Never commit `.env` to git.

# ===== Core =====
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/agent.db
POLL_INTERVAL_SECONDS=60

# ===== AI provider =====
# Use Anthropic (Claude Haiku) by default; switch to OpenAI by changing AI_PROVIDER.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_MODEL=claude-haiku-4-5-20251001

# ===== News sources =====
# Comma-separated RSS URLs to poll
RSS_FEEDS=https://feeds.reuters.com/reuters/topNews,https://rss.cnn.com/rss/cnn_latest.rss
NEWSAPI_KEY=

# ===== X (Twitter) =====
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ===== Threads =====
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel

# ===== YouTube =====
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=

# ===== beehiiv =====
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ===== Feature flags =====
ENABLE_X=true
ENABLE_THREADS=false
ENABLE_TELEGRAM=true
ENABLE_YOUTUBE=false
ENABLE_BEEHIIV=false
DRY_RUN=true
